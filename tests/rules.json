{
    "id": "local_111",
    "phase": "access",
    "conditions": [
        {
            "multi_match": false,
            "op": "rx",
            "transform": ["urlDecode"],
            "value": "^(/wp-admin|/wp-login).*",
            "variables": ["request.raw_path"]
        }
    ],
    "action": {
        "set_variable": {
            "name": "google_oauth_path_matched",
            "value": true,
            "type": "shared"
        }
    }
}


